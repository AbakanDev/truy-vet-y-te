<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bluemint">
    <View
            android:id="@+id/bgWhiteForm"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="100dp"
            android:background="@drawable/img_white_bg_login"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <!-- ScrollView để có thể cuộn màn hình khi form quá dài -->
    <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:scrollbars="none"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/bgWhiteForm">

        <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="40dp">

            <!-- Nút Back và Tiêu đề -->
            <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="32dp"
                    android:src="@drawable/img_left_arrow"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="ĐIỀN THÔNG TIN"
                    android:textColor="@color/darkbluemint"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/btnBack"
                    app:layout_constraintStart_toEndOf="@id/btnBack"
                    app:layout_constraintTop_toTopOf="@id/btnBack" />

            <!-- 1. Tên Đầy Đủ -->
            <TextView
                    android:id="@+id/labelName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="24dp"
                    android:text="Tên Đầy Đủ"
                    android:textColor="@color/darkbluemint"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/edtFullName"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/img_blue_round_bg_login"
                    android:backgroundTint="@null"
                    android:hint="Lê Huỳnh Thảo An"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="20dp"
                    android:textStyle="bold"
                    android:textColor="@color/darkbluemint"
                    android:textColorHint="@color/darklightbluemint"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelName" />

            <!-- 2. Hàng ngang chứa Ngày Sinh & Giới Tính -->
            <LinearLayout
                    android:id="@+id/rowDobGender"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/edtFullName">

                <!-- Cột Ngày sinh (Chiếm 5.5 phần) -->
                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="5.5"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Ngày Tháng Năm Sinh"
                            android:textColor="@color/darkbluemint"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edtDob"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/img_blue_round_bg_login"
                            android:backgroundTint="@null"
                            android:drawableEnd="@drawable/img_calendar"
                            android:drawablePadding="8dp"
                            android:hint="DD/MM/YY"
                            android:inputType="date"
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/darkbluemint"
                            android:textStyle="bold"
                            android:textColorHint="@color/darklightbluemint"
                            android:textSize="14sp" />
                </LinearLayout>

                <!-- Khoảng cách giữa 2 cột -->
                <View
                        android:layout_width="16dp"
                        android:layout_height="match_parent" />

                <!-- Cột Giới tính (Chiếm 4.5 phần) -->
                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="4.5"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="Giới tính"
                            android:textColor="@color/darkbluemint"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    <RadioGroup
                            android:id="@+id/rgGender"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                        <RadioButton
                                android:id="@+id/rbFemale"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:buttonTint="@color/darklightbluemint"
                                android:text="Nữ"
                                android:textColorHint="@color/darklightbluemint"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        <RadioButton
                                android:id="@+id/rbMale"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:textColorHint="@color/darklightbluemint"
                                android:text="Nam"
                                android:textColor="@color/darkbluemint"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                    </RadioGroup>
                </LinearLayout>
            </LinearLayout>

            <!-- 3. Địa chỉ nhà ở -->
            <TextView
                    android:id="@+id/labelAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="16dp"
                    android:text="Địa chỉ nhà ở"
                    android:textColor="@color/darkbluemint"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rowDobGender" />

            <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/edtAddress"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/img_blue_round_bg_login"
                    android:backgroundTint="@null"
                    android:hint="Đường 123, Phường 123, TPHCM"
                    android:inputType="textPostalAddress"
                    android:paddingHorizontal="20dp"
                    android:textColor="@color/darkbluemint"
                    android:textColorHint="@color/darklightbluemint"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelAddress" />

            <!-- 4. Email -->
            <TextView
                    android:id="@+id/labelEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="16dp"
                    android:text="Email"
                    android:textColor="@color/darkbluemint"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/edtAddress" />

            <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/edtEmail"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/img_blue_round_bg_login"
                    android:backgroundTint="@null"
                    android:hint="example@gmail.com"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="20dp"
                    android:textColor="@color/darkbluemint"
                    android:textColorHint="@color/darklightbluemint"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelEmail" />

            <!-- 5. Số điện thoại -->
            <TextView
                    android:id="@+id/labelPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="16dp"
                    android:text="Số điện thoại:"
                    android:textColor="@color/darkbluemint"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/edtEmail" />

            <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/edtPhone"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/img_blue_round_bg_login"
                    android:backgroundTint="@null"
                    android:hint="012345678901"
                    android:inputType="phone"
                    android:paddingHorizontal="20dp"
                    android:textColor="@color/darkbluemint"
                    android:textColorHint="@color/darklightbluemint"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelPhone" />

            <!-- Nút Submit (Mũi tên tròn) -->
            <ImageView
                    android:id="@+id/btnSubmit"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginTop="32dp"
                    android:src="@drawable/img_right_arrow"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/edtPhone" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>