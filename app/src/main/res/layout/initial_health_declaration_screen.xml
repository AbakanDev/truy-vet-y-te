<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F0FAFE"
            android:fillViewport="true">


    <!-- KHỐI NỘI DUNG CHÍNH (Đã xóa Header cứng để dùng Header chung) -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="80dp"> <!-- Padding bottom để không bị Bottom Nav che mất -->


        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giấy Khai Báo Sức Khỏe"
                android:textColor="@color/bluewithcheckbox"
                android:textSize="24sp"
                android:textStyle="bold" />


        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Vui lòng khai báo đầy đủ và trung thực thông tin"
                android:textColor="#6FBBE2"
                android:textSize="14sp"
                android:textStyle="bold" />


        <!-- CARD 1: TRIỆU CHỨNG -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">


            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">


                <!-- Đã chuyển dấu * ra sau -->
                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đánh giá triệu chứng: "
                            android:textColor="@color/bluewithcheckbox"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="*"
                            android:textColor="#FF0000"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                </LinearLayout>


                <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sốt" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen"/>
                <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Khó thở" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen"/>
                <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đau họng" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen"/>
                <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mệt mỏi" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen"/>
                <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mất vị giác/khứu giác" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen"/>
                <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ho" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen"/>
                <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Không có triệu chứng" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- CARD 2: BỆNH NỀN -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">


            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">


                <!-- Đã chuyển dấu * ra sau -->
                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đánh giá bệnh nền: "
                            android:textColor="@color/bluewithcheckbox"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="*"
                            android:textColor="#FF0000"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                </LinearLayout>


                <RadioGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                    <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Có" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen" android:layout_marginEnd="32dp"/>
                    <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Không" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen"/>
                </RadioGroup>


                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="8dp"
                        android:text="Nếu có:"
                        android:textColor="@color/bluewithcheckbox"
                        android:textStyle="bold"/>


                <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Huyết áp cao, thấp, bla bla"
                        android:textSize="14sp"
                        android:textColorHint="#A0A0A0"
                        android:backgroundTint="#D3D3D3"
                        android:paddingBottom="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- CARD 3: NGUY CƠ -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">


            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">


                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đánh giá nguy cơ:"
                        android:textColor="@color/bluewithcheckbox"
                        android:textSize="16sp"
                        android:textStyle="bold" />


                <!-- Câu hỏi 1: Đã chuyển dấu * ra sau -->
                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trong 14 ngày qua, bạn có tiếp xúc với F0 không? "
                            android:textColor="@color/bluelightgreen"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="*"
                            android:textColor="#FF0000"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                </LinearLayout>


                <RadioGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="16dp">
                    <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Có" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen" android:layout_weight="1"/>
                    <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Không" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen" android:layout_weight="1"/>
                </RadioGroup>


                <!-- Câu hỏi 2: Đã chuyển dấu * ra sau -->
                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trong 14 ngày qua, bạn có đi từ vùng dịch không? "
                            android:textColor="@color/bluelightgreen"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="*"
                            android:textColor="#FF0000"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                </LinearLayout>


                <RadioGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginStart="16dp">
                    <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Có" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen" android:layout_weight="1"/>
                    <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Không" android:textColor="@color/bluelightgreen" android:buttonTint="@color/bluelightgreen" android:layout_weight="1"/>
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- PHẦN CAM KẾT (Dấu * vốn đã ở cuối rồi) -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:layout_marginStart="4dp">


            <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/bluelightgreen" />


            <!-- Mình có sửa lỗi chính tả ở đây giúp bạn: "thông khai báo" -> "thông tin khai báo" -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tôi cam kết thông tin khai báo là đúng sự thật "
                    android:textColor="@color/bluelightgreen"
                    android:textSize="14sp"
                    android:textStyle="bold" />


            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="*"
                    android:textColor="#FF0000"
                    android:textSize="16sp"
                    android:textStyle="bold" />
        </LinearLayout>


        <Button
                android:id="@+id/btnHoanTat"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="30dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:text="HOÀN TẤT"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/darklightbluemint"
                app:cornerRadius="28dp" />


    </LinearLayout>
</ScrollView>
